# Copy to terraform.tfvars and edit. Only one target_platform block needs to
# be filled in; the rest are ignored.

target_platform = "azure"   # azure | aws | gcp | kubernetes | docker
stack           = "submitters"
environment     = "dev"
name_prefix     = "ahdqp"
image_tag       = "v1.0.0"

# --- Azure ---------------------------------------------------------------
region = "eastus2"
azure = {
  subscription_id = "00000000-0000-0000-0000-000000000000"
  aks_node_size   = "Standard_D2s_v5"
  aks_node_count  = 2
}

