{
  "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.153.json",
  "name": "CMSBrand-b7e21d90.json",
  "dataColors": ["#0071BC", "#112E51", "#02BFE7", "#2E8540", "#FDB81E", "#E31C3D", "#4C2C92", "#5B616B"],
  "good": "#2E8540",
  "neutral": "#FDB81E",
  "bad": "#E31C3D",
  "maximum": "#0071BC",
  "center": "#5B9BD5",
  "minimum": "#DCE9F5",
  "null": "#AEB0B5",
  "foreground": "#1B1B1B",
  "foregroundNeutralSecondary": "#5B616B",
  "background": "#FFFFFF",
  "backgroundLight": "#E4EEF7",
  "secondaryBackground": "#DCE9F5",
  "tableAccent": "#0071BC",
  "textClasses": {
    "callout": { "fontSize": 32, "fontFace": "Segoe UI Semibold", "color": "#0071BC" },
    "title": { "fontSize": 13, "fontFace": "Segoe UI Semibold", "color": "#112E51" },
    "header": { "fontSize": 12, "fontFace": "Segoe UI Semibold", "color": "#112E51" },
    "label": { "fontSize": 10, "fontFace": "Segoe UI Variable, Segoe UI, sans-serif", "color": "#1B1B1B" }
  },
  "visualStyles": {
    "*": {
      "*": {
        "border": [{ "show": true, "color": { "solid": { "color": "#D6D7D9" } }, "radius": 8 }],
        "dropShadow": [{ "show": false }],
        "padding": [{ "top": 8, "bottom": 8, "left": 8, "right": 8 }],
        "categoryAxis": [{ "gridlineStyle": "dotted", "gridlineColor": { "solid": { "color": "#F3F2F1" } } }],
        "valueAxis": [{ "gridlineStyle": "dotted", "gridlineColor": { "solid": { "color": "#F3F2F1" } } }]
      }
    },
    "tableEx": {
      "*": {
        "columnHeaders": [{
          "autoSizeColumnWidth": true,
          "columnAdjustment": "growToFit",
          "backColor": { "solid": { "color": "#112E51" } },
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "bold": true
        }],
        "values": [{
          "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
          "backColorSecondary": { "solid": { "color": "#F0F5FA" } },
          "fontColorPrimary": { "solid": { "color": "#1B1B1B" } },
          "fontColorSecondary": { "solid": { "color": "#1B1B1B" } }
        }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{
          "autoSizeColumnWidth": true,
          "columnAdjustment": "growToFit",
          "backColor": { "solid": { "color": "#112E51" } },
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "bold": true
        }],
        "values": [{
          "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
          "backColorSecondary": { "solid": { "color": "#F0F5FA" } },
          "fontColorPrimary": { "solid": { "color": "#1B1B1B" } },
          "fontColorSecondary": { "solid": { "color": "#1B1B1B" } }
        }]
      }
    },
    "cardVisual": {
      "*": {
        "value": [{ "bold": true, "$id": "default" }],
        "label": [{ "show": true, "$id": "default" }],
        "cardCalloutArea": [{ "paddingUniform": 0 }],
        "title": [{ "show": false }]
      }
    },
    "textbox": {
      "*": {
        "padding": [{ "top": 0, "bottom": 0, "left": 0, "right": 0 }],
        "background": [{ "show": false }],
        "border": [{ "show": false }]
      }
    },
    "barChart": {
      "*": {
        "labels": [{ "show": true, "fontSize": 10 }],
        "valueAxis": [{ "show": false, "gridlineShow": false, "showAxisTitle": false }],
        "categoryAxis": [{ "show": true, "fontSize": 10, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "innerPadding": 20, "gridlineShow": false }],
        "dataPoint": [{ "borderShow": false }],
        "legend": [{ "show": false }]
      }
    },
    "clusteredBarChart": {
      "*": {
        "labels": [{ "show": true, "fontSize": 10 }],
        "valueAxis": [{ "show": false, "gridlineShow": false, "showAxisTitle": false }],
        "categoryAxis": [{ "show": true, "fontSize": 10, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "innerPadding": 20, "gridlineShow": false }],
        "dataPoint": [{ "borderShow": false }],
        "legend": [{ "show": true, "fontSize": 9, "labelColor": { "solid": { "color": "#5B616B" } } }]
      }
    },
    "columnChart": {
      "*": {
        "labels": [{ "show": true, "fontSize": 10 }],
        "valueAxis": [{ "show": false, "gridlineShow": false, "showAxisTitle": false }],
        "categoryAxis": [{ "show": true, "fontSize": 10, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "innerPadding": 20, "gridlineShow": false }],
        "dataPoint": [{ "borderShow": false }],
        "legend": [{ "show": false }]
      }
    },
    "clusteredColumnChart": {
      "*": {
        "labels": [{ "show": true, "fontSize": 10 }],
        "valueAxis": [{ "show": false, "gridlineShow": false, "showAxisTitle": false }],
        "categoryAxis": [{ "show": true, "fontSize": 10, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "innerPadding": 20, "gridlineShow": false }],
        "dataPoint": [{ "borderShow": false }],
        "legend": [{ "show": false }]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [{ "strokeWidth": 2.5, "lineChartType": "smooth", "interpolationSmooth": "monotoneX", "areaShow": true, "areaMatchStrokeColor": true }],
        "dataPoint": [{ "transparency": 85 }],
        "labels": [{ "show": true, "labelPosition": "Above", "fontSize": 9, "color": { "solid": { "color": "#1B1B1B" } }, "labelDensity": 25 }],
        "categoryAxis": [{ "show": true, "fontSize": 10, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "gridlineShow": false }],
        "valueAxis": [{ "show": true, "fontSize": 9, "labelColor": { "solid": { "color": "#5B616B" } }, "showAxisTitle": false, "gridlineStyle": "dotted", "gridlineColor": { "solid": { "color": "#E8E8E8" } } }],
        "legend": [{ "show": false }]
      }
    },
    "slicer": {
      "*": {
        "header": [{ "fontFamily": "Segoe UI Semibold", "textSize": 10, "fontColor": { "solid": { "color": "#112E51" } }, "outlineStyle": 0 }],
        "items": [{ "fontFamily": "Segoe UI Variable, Segoe UI, sans-serif", "textSize": 9, "fontColor": { "solid": { "color": "#1B1B1B" } }, "outlineStyle": 0, "padding": 2 }],
        "date": [{ "fontFamily": "Segoe UI Variable, Segoe UI, sans-serif", "textSize": 9, "fontColor": { "solid": { "color": "#1B1B1B" } } }]
      }
    }
  }
}
