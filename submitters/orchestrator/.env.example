# Azure Storage Configuration
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_CONNECTION_STRING=

# Microsoft Agent Framework / Azure AI Foundry Configuration
# Required for AI Agent capabilities
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.api.azureml.ms
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# Optional for AI CQL engine:
# - FOUNDRY_API_KEY (or AZURE_OPENAI_API_KEY) lets the engine use key auth
#   if tenant policies block workload identity token issuance.
# - AI_CQL_EXCLUDE_WORKLOAD_IDENTITY=true skips WorkloadIdentityCredential and
#   allows other DefaultAzureCredential sources (for local/dev troubleshooting).
FOUNDRY_API_KEY=
AI_CQL_EXCLUDE_WORKLOAD_IDENTITY=false
