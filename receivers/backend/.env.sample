APPINSIGHTS_CONNECTIONSTRING=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=
# Quality Measures Workbench (Cosmos DB SQL API, database `dq`)
# - catalog container holds measures + tags + regulatory agencies (programs)
#   via /docType partition (docType in {measure, tag, agency})
# - cohorts container holds cohort definitions + member FHIR bundles
#   + DEQM measure_reports + submissions via /docType partition
#   (docType in {cohort, member, measurement_execution, measure_report, submission})
COSMOSDB_DATABASE=dq
COSMOSDB_CATALOG_COLLECTION=catalog
COSMOSDB_COHORTS_COLLECTION=cohorts
COSMOSDB_USERNAME=
COSMOSDB_PASSWORD=
COSMOSDB_HOST=
COSMOSDB_OPTIONS=
# RL fine-tuning database (orchestrator only)
COSMOS_DATABASE_NAME=dq_rl

# ---------------------------------------------------------------------------
# OAuth 2.0 / Microsoft Entra ID — Receiver API protection (issue #16)
# ---------------------------------------------------------------------------
# The Receiver validates inbound bearer tokens minted by Submitters via the
# client-credentials flow. Configure the Receiver App Registration below.
#   - ENTRA_TENANT_ID:  home tenant of the Receiver App Registration
#                       (falls back to AZURE_TENANT_ID when unset).
#   - ENTRA_CLIENT_ID:  Application (client) ID of the Receiver App Registration
#                       (falls back to AZURE_CLIENT_ID when unset).
#   - RECEIVER_APP_ID_URI: Application ID URI exposed by the Receiver, e.g.
#                       api://dq-receiver-api. Accepted as a valid token audience.
#   - ALLOWED_TENANTS:  comma-separated tenant IDs permitted to call this
#                       Receiver. Empty => single-tenant (home tenant only).
#                       Use "*" to accept any tenant (multi-tenant).
#   - REQUIRED_ROLE:    default application role required for submission
#                       endpoints (Receiver.Submit | Receiver.Read | Receiver.Admin).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
RECEIVER_APP_ID_URI=
ALLOWED_TENANTS=
REQUIRED_ROLE=Receiver.Submit