APPINSIGHTS_CONNECTIONSTRING=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=
# Quality Measures Workbench (Cosmos DB SQL API, database `dq`)
# - catalog container holds measures + tags + regulatory agencies (programs)
#   via /docType partition (docType in {measure, tag, agency})
# - cohorts container holds cohort definitions + member FHIR bundles
#   + DEQM measure_reports + submissions via /docType partition
#   (docType in {cohort, member, measurement_execution, measure_report, submission})
COSMOSDB_DATABASE=dq
COSMOSDB_CATALOG_COLLECTION=catalog
COSMOSDB_COHORTS_COLLECTION=cohorts
COSMOSDB_USERNAME=
COSMOSDB_PASSWORD=
COSMOSDB_HOST=
COSMOSDB_OPTIONS=
# RL fine-tuning database (orchestrator only)
COSMOS_DATABASE_NAME=dq_rl

# ---------------------------------------------------------------------------
# OAuth 2.0 / Microsoft Entra ID — Submitter -> Receiver calls (issue #16)
# ---------------------------------------------------------------------------
# When the Submitter dispatches DEQM MeasureReports to the Receiver stack it
# acquires an Entra ID access token via the client-credentials flow and
# attaches it as a bearer token. Configure the Submitter App Registration and
# the Receiver's App ID URI below. Leave blank for unauthenticated local dev.
#   - ENTRA_TENANT_ID:      tenant that issues the token (Submitter's tenant;
#                           for cross-tenant, the Receiver's tenant).
#   - ENTRA_CLIENT_ID:      Application (client) ID of the Submitter App Registration.
#   - ENTRA_CLIENT_SECRET:  client secret. Prefer Key Vault / managed identity
#                           in production; when unset, DefaultAzureCredential
#                           (managed identity / workload identity) is used.
#   - ENTRA_CLIENT_CERTIFICATE_PATH: optional PEM certificate for cert-based auth.
#   - RECEIVER_APP_ID_URI:  the Receiver's Application ID URI, e.g.
#                           api://dq-receiver-api. The requested scope becomes
#                           <RECEIVER_APP_ID_URI>/.default.
#   - RECEIVER_OAUTH_SCOPE: optional explicit scope override (takes precedence
#                           over RECEIVER_APP_ID_URI).
#   - RECEIVERS_BACKEND_BASE_URL: base URL of the Receiver backend to dispatch to.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_CLIENT_CERTIFICATE_PATH=
RECEIVER_APP_ID_URI=
RECEIVER_OAUTH_SCOPE=
RECEIVERS_BACKEND_BASE_URL=